# The service does not start its administration or enrollment routes without
# explicit authenticators. Configure secrets through the deployment platform;
# never commit them to this repository.
PORT=8080
HOST=127.0.0.1
# Development-only operator access token: use at least 32 URL-safe characters.
# Replace this static-token adapter with OIDC or another identity provider before production.
ADMIN_API_TOKEN=
# Set only when the service listens exclusively on loopback behind the installer-managed Nginx.
TRUST_PROXY_ADMIN=false
# Optional JSON state file. The production installer uses /var/lib/wdtt-fleet-manager/state.json.
STATE_FILE=
# Public agent endpoint (optional). Keep it distinct from the operator URL.
AGENT_ENDPOINT=
